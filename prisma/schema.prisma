generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  passwordHash String
  createdAt    DateTime @default(now()) @db.DateTime(0)
  updatedAt    DateTime @updatedAt @db.DateTime(0)

  sessions      Session[]
  uploadedFiles File[]    @relation("FileUploadedBy")
  updatedFiles  File[]    @relation("FileUpdatedBy")

  @@map("users")
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String
  revoked          Boolean  @default(false)
  expiresAt        DateTime @db.DateTime(0)
  createdAt        DateTime @default(now()) @db.DateTime(0)
  updatedAt        DateTime @updatedAt @db.DateTime(0)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@map("sessions")
}

model File {
  id           String   @id @default(cuid())
  uploadedById String
  updatedById  String?
  originalName String
  extension    String
  mimeType     String
  size         Int
  storedName   String   @unique
  uploadedAt   DateTime @default(now()) @db.DateTime(0)
  updatedAt    DateTime @updatedAt @db.DateTime(0)

  uploadedBy User  @relation("FileUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  updatedBy  User? @relation("FileUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@map("files")
}
