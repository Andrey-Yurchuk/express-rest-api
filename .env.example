# App
PORT=3000
NODE_ENV=development

# MySQL
MYSQL_ROOT_PASSWORD=example_root_password
MYSQL_DATABASE=express_rest_api
MYSQL_USER=example_user
MYSQL_PASSWORD=example_password
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Prisma
DATABASE_URL="mysql://example_user:example_password@localhost:3306/express_rest_api"

# JWT
JWT_ACCESS_SECRET=example_access_secret_change_me
JWT_ACCESS_TTL=600
JWT_REFRESH_SECRET=example_refresh_secret_change_me
JWT_REFRESH_TTL=604800

# File uploads
UPLOAD_DIR=uploads
